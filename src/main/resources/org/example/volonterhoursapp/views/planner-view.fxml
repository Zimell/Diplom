<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.volonterhoursapp.controller.PlannerController"
      spacing="14">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <VBox spacing="2">
        <Label text="План мероприятий" styleClass="title-label"/>
        <Label text="Запись волонтёров и подсчёт явки по каждому мероприятию." styleClass="subtitle-label"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <CheckBox fx:id="futureOnly" text="Только предстоящие" selected="true" onAction="#onFilter"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Обновить" styleClass="action-button" onAction="#onRefresh"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTitle"        text="Мероприятие"   prefWidth="240"/>
            <TableColumn fx:id="colDateTime"     text="Дата/время"    prefWidth="150"/>
            <TableColumn fx:id="colLocation"     text="Место"         prefWidth="150"/>
            <TableColumn fx:id="colType"         text="Тип"           prefWidth="120"/>
            <TableColumn fx:id="colParticipants" text="Записано"      prefWidth="100"/>
            <TableColumn fx:id="colPending"      text="Ожидает"       prefWidth="100"/>
            <TableColumn fx:id="colHours"        text="Часов подтв."  prefWidth="120"/>
        </columns>
    </TableView>

    <VBox spacing="10" styleClass="card">
        <Label text="Записать волонтёра на выбранное мероприятие" styleClass="section-header"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Волонтёр" styleClass="muted"/>
            <ComboBox fx:id="volunteerCombo" prefWidth="300"/>
            <Label text="Часы (план)" styleClass="muted"/>
            <TextField fx:id="hoursField" prefWidth="100" promptText="например 4"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Записать" styleClass="primary-button" onAction="#onEnroll"/>
        </HBox>
        <Label fx:id="selectedEventLabel" text="" styleClass="muted"/>
    </VBox>
</VBox>
