<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.volonterhoursapp.controller.ParticipationsController"
      spacing="14">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <VBox spacing="2">
        <Label text="Участия" styleClass="title-label"/>
        <Label text="Учёт участия волонтёров в мероприятиях и подтверждение отработанных часов куратором."
               styleClass="subtitle-label"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <CheckBox fx:id="onlyPending" text="Только ожидающие подтверждения"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Подтвердить выбранное" styleClass="primary-button" onAction="#onConfirm"/>
        <Button text="Снять подтверждение"   styleClass="action-button"  onAction="#onRevoke"/>
    </HBox>

    <SplitPane dividerPositions="0.62" VBox.vgrow="ALWAYS">
        <TableView fx:id="table">
            <columns>
                <TableColumn fx:id="colId"        text="#"           prefWidth="60"/>
                <TableColumn fx:id="colVolunteer" text="Волонтёр"    prefWidth="220"/>
                <TableColumn fx:id="colEvent"     text="Мероприятие" prefWidth="240"/>
                <TableColumn fx:id="colHours"     text="Часы"        prefWidth="80"/>
                <TableColumn fx:id="colStatus"    text="Статус"      prefWidth="140"/>
                <TableColumn fx:id="colConfirmedBy" text="Подтвердил" prefWidth="160"/>
            </columns>
        </TableView>

        <VBox spacing="10" styleClass="card">
            <Label text="Запись участия" styleClass="section-header"/>

            <Label text="Волонтёр"     styleClass="muted"/>
            <ComboBox fx:id="volunteerCombo" maxWidth="Infinity"/>

            <Label text="Мероприятие"  styleClass="muted"/>
            <ComboBox fx:id="eventCombo"     maxWidth="Infinity"/>

            <Label text="Отработанные часы" styleClass="muted"/>
            <TextField fx:id="hoursField" promptText="например 4.5"/>

            <Label fx:id="statusLabel" text="" styleClass="muted"/>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="10">
                <Button text="Новая"     styleClass="action-button"  onAction="#onNew"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Удалить"   styleClass="danger-button"  onAction="#onDelete"/>
                <Button text="Сохранить" styleClass="primary-button" onAction="#onSave"/>
            </HBox>
        </VBox>
    </SplitPane>
</VBox>
